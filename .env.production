# Vite auto-loads this during `vite build` (production mode) on any platform (Vercel etc.).
# Values here are non-secret build config; real shell/dashboard env vars take precedence,
# so this ADDS the OIDC config without overriding the deployed backend URL.
VITE_APP_ENV=production
VITE_BACKEND_URL=https://lmsapi.mastereducation.kz
VITE_APP_NAME=LMS Platform

# --- SSO Phase 2 (OIDC "Continue with Master Education") — Zitadel Cloud ---
VITE_OIDC_AUTHORITY=https://auth.mastereducation.kz
VITE_OIDC_CLIENT_ID=381061947262549203
VITE_OIDC_REDIRECT_URI=https://lms.mastereducation.kz/auth/callback
VITE_OIDC_POST_LOGOUT_URI=https://lms.mastereducation.kz/login
VITE_OIDC_SCOPES=openid profile email offline_access urn:zitadel:iam:org:project:id:381051836439779891:aud
