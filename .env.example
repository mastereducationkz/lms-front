# lms-front build-time env (Vite). Copy to .env.local for dev.

# Backend API base
VITE_BACKEND_URL=http://localhost:8000

# --- SSO Phase 2 (OIDC "Continue with Master Education" PKCE login) ---
# The button + flow are HIDDEN unless VITE_OIDC_AUTHORITY, VITE_OIDC_CLIENT_ID and
# VITE_OIDC_REDIRECT_URI are all set — so a build without these is unchanged.
# Enable ONLY after the LMS backend has OIDC_ACCEPT=true (else the button appears but
# the returned token is rejected). Values for our Zitadel Cloud tenant:
# VITE_OIDC_AUTHORITY=https://mastereducation-fvbwjk.eu1.zitadel.cloud
# VITE_OIDC_CLIENT_ID=381061947262549203                         # lms-web client id
# VITE_OIDC_REDIRECT_URI=https://lms.mastereducation.kz/auth/callback
# VITE_OIDC_POST_LOGOUT_URI=https://lms.mastereducation.kz/login
# Optional: add the Zitadel project-audience scope to force the lms-api resource id into aud
# VITE_OIDC_SCOPES=openid profile email offline_access urn:zitadel:iam:org:project:id:381051836439779891:aud
